# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# See https://editorconfig.org for more information

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.{py,pyw,pyx,pxd,pxitext}]
indent_style = space
indent_size = 4
max_line_length = 100

# YAML files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Makefile
[Makefile]
indent_style = tab

# Batch files
[*.{bat,cmd}]
end_of_line = crlf

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# Configuration files
[{.editorconfig,.gitignore,.gitattributes}]
indent_style = space
indent_size = 2

# Setup files
[{setup.py,setup.cfg,pyproject.toml}]
indent_style = space
indent_size = 2

# Ignore on export
[{.editorconfig,.gitignore,.gitattributes,CONTRIBUTING.md,CODE_OF_CONDUCT.md}]
trim_trailing_whitespace = false
