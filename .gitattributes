# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf
*.pxd text eol=lf
*.pxitext eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# JSON
*.json text eol=lf
*.jsonc text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf
CHANGELOG.md text eol=lf
CONTRIBUTING.md text eol=lf
CODE_OF_CONDUCT.md text eol=lf

# Ignore on export
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore

# Data files (binary)
*.joblib binary
*.pkl binary
*.pickle binary
*.csv text eol=lf

# Log files
*.log text eol=lf
